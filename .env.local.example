# ── Local LLM (Ollama) ────────────────────────────────────────────────────────
# Run Ollama locally via Docker (GPU recommended):
#   docker run -d --gpus=all -v ollama_data:/root/.ollama -p 11434:11434 --name ollama ollama/ollama
#   docker exec ollama ollama pull gemma3:12b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b

# ── Speech API (Piper TTS + Whisper STT, Condition A only) ────────────────────
# FastAPI service in speech-api/ (Docker). Exposes /tts and /stt on port 5001.
# If unavailable, TTS falls back to the browser Web Speech API automatically.
SPEECH_API_URL=http://localhost:5001

# ── Telemetry / data ──────────────────────────────────────────────────────────
# Where session JSON + the events log + assignment state are written.
# Defaults to ./data if unset.
# DATA_DIR=./data

# ── App configuration ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
