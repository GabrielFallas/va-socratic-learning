{
  "name": "va-socratic-learning",
  "version": "1.0.0",
  "description": "Repositorio del proyecto de investigacion sobre un agente virtual de tutoria socratica para el desarrollo de logica de programacion y resolucion de problemas en entornos STEM. El objetivo es evaluar si una interaccion basada en preguntas reflexivas y pistas graduales mejora la comprension y la autonomia del estudiante sin entregar soluciones directas.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GabrielFallas/va-socratic-learning.git"
  },
  "keywords": [],
  "author": "",
